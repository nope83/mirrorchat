# MirrorChat Configuration
# Copy this file to .env and fill in YOUR values:
#   cp .env.example .env
#
# NEVER commit .env to git — it's in .gitignore

# Your OpenAI API key (used when users enter a valid promo code)
OPENAI_API_KEY=sk-your-key-here

# Valid promo codes — comma-separated, case-insensitive
# These are the codes you give to people to use YOUR API key for free
PROMO_CODES=CODE1,CODE2,CODE3

# Flask secret (change to any random string)
SECRET_KEY=change-me-to-something-random

# Port (default 5000)
PORT=5000
